#!/usr/bin/env bash
set -euo pipefail

# Telescope setup — symlinks skill directories into ~/.claude/skills/
# so Claude Code can discover them.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$HOME/.claude/skills"

mkdir -p "$SKILLS_DIR"

SKILLS=(telescope-explore telescope-plan telescope-review telescope-execute telescope-add-feature-plan)

for skill in "${SKILLS[@]}"; do
  src="$SCRIPT_DIR/$skill"
  dest="$SKILLS_DIR/$skill"

  if [ -L "$dest" ]; then
    rm "$dest"
  elif [ -d "$dest" ]; then
    echo "Warning: $dest exists and is not a symlink — skipping"
    continue
  fi

  ln -s "$src" "$dest"
done

echo "Telescope installed: ${SKILLS[*]}"
echo "Run /telescope-explore in Claude Code to start."
